---
/* Real numbers only — no vague claims, no client names. */
const stats = [
  { big: '40 → 300+', small: 'seats. Same discipline at every size.' },
  { big: 'Same week', small: 'edited clips, while the event is still in the feed.' },
  { big: '1 crew', small: 'AV, broadcast, and media. Zero handoffs.' },
];
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 border-t border-b border-line py-10">
  {stats.map((s) => (
    <div class="text-center px-4">
      <p class="font-display text-xl md:text-2xl text-bone font-semibold">{s.big}</p>
      <p class="text-muted text-sm mt-1">{s.small}</p>
    </div>
  ))}
</div>
