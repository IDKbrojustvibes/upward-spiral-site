---
import SignalBar from './SignalBar.astro';

interface Props {
  heading: string;
  buttonText: string;
  href?: string;
}
const { heading, buttonText, href = '/contact' } = Astro.props;
---

<section class="bg-panel border-t border-line">
  <div class="max-w-5xl mx-auto px-6 py-20 text-center flex flex-col items-center gap-6">
    <SignalBar class="mx-auto" />
    <h3 class="text-3xl md:text-4xl font-semibold text-bone">{heading}</h3>
    <a href={href} class="btn-signal">{buttonText}</a>
  </div>
</section>
