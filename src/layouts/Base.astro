---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Atlanta's broadcast-grade event production company — corporate AV, broadcasting, and event media.",
} = Astro.props;

const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/studiolive', label: 'StudioLive' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0E1116" />
    <title>{title} · Upward Spiral Productions</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="border-b border-line bg-ink/95 backdrop-blur sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="font-display font-bold tracking-tight text-bone text-lg">
          UPWARD SPIRAL
        </a>
        <nav class="hidden md:flex items-center gap-8">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`font-display text-sm uppercase tracking-wide transition-colors ${
                currentPath === link.href ? 'text-signal' : 'text-bone hover:text-signal'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="/contact" class="btn-signal !px-5 !py-2.5 !text-xs">Get a quote →</a>
        </nav>
        <a href="/contact" class="md:hidden btn-signal !px-4 !py-2 !text-xs">Quote →</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-line bg-panel">
      <div class="max-w-7xl mx-auto px-6 py-14 flex flex-col md:flex-row md:justify-between gap-10">
        <div class="flex flex-col gap-3">
          <span class="font-display font-bold text-bone text-lg">UPWARD SPIRAL</span>
          <p class="text-muted text-sm max-w-xs">Atlanta · Corporate AV · Broadcasting · Event Media</p>
        </div>
        <nav class="flex flex-col gap-2">
          {navLinks.map((link) => (
            <a href={link.href} class="text-muted hover:text-signal text-sm transition-colors">{link.label}</a>
          ))}
        </nav>
        <div class="flex flex-col gap-2 text-sm text-muted">
          <a href="mailto:dominic@upwardspiralpro.com" class="hover:text-signal transition-colors">dominic@upwardspiralpro.com</a>
          <a href="tel:+14704957342" class="hover:text-signal transition-colors">(470) 495-7342</a>
          <span>Atlanta, GA</span>
        </div>
      </div>
      <div class="border-t border-line">
        <p class="max-w-7xl mx-auto px-6 py-6 text-xs text-muted">
          © 2026 Upward Spiral Productions
        </p>
      </div>
    </footer>
  </body>
</html>
