---
import '../styles/global.css';
import Tally from '../components/Tally.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Atlanta's broadcast-grade event production company — corporate AV, broadcasting, and event media.",
} = Astro.props;

const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/studiolive', label: 'StudioLive' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const canonical = new URL(Astro.url.pathname, 'https://upwardspiralpro.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0E1116" />
    <title>{title} · Upward Spiral Productions</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Fonts are self-hosted in /public/fonts. Preload the two that paint first. -->
    <link rel="preload" href="/fonts/archivo-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://upwardspiralpro.com/og-image.png" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Upward Spiral Productions" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://upwardspiralpro.com/og-image.png" />
  </head>
  <body>
    <header class="border-b border-line bg-ink/95 backdrop-blur sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a
          href="/"
          class="flex items-center gap-3 font-display font-bold tracking-tight text-bone text-lg"
          aria-label="Upward Spiral Productions — home"
        >
          <Tally size={26} />
          UPWARD SPIRAL
        </a>
        <nav class="hidden md:flex items-center gap-8">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`font-display text-sm uppercase tracking-wide transition-colors ${
                currentPath === link.href ? 'text-signal' : 'text-bone hover:text-signal'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="/contact" class="btn-signal !px-5 !py-2.5 !text-xs">Get a quote →</a>
        </nav>
        <a href="/contact" class="md:hidden btn-signal !px-4 !py-2 !text-xs">Quote →</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-line bg-panel">
      <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-[1.3fr_1fr_1fr] gap-12">
        <div class="flex flex-col gap-3">
          <span class="font-display font-bold text-bone text-lg tracking-tight">UPWARD SPIRAL</span>
          <p class="text-muted text-sm leading-relaxed">Corporate AV · Broadcasting · Event Media</p>
        </div>
        <div class="flex flex-col gap-4">
          <span class="eyebrow">Navigate</span>
          <nav class="flex flex-col gap-2.5">
            {navLinks.map((link) => (
              <a href={link.href} class="text-muted hover:text-signal text-sm transition-colors">{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="flex flex-col gap-4">
          <span class="eyebrow">Contact</span>
          <div class="flex flex-col gap-2.5 text-sm text-muted">
            <a href="mailto:dominic@upwardspiralpro.com" class="hover:text-signal transition-colors">dominic@upwardspiralpro.com</a>
            <a href="tel:+14704957342" class="hover:text-signal transition-colors">(470) 495-7342</a>
            <span>Atlanta, GA</span>
          </div>
        </div>
      </div>
      <div class="border-t border-line">
        <p class="max-w-7xl mx-auto px-6 py-6 text-xs text-muted">
          © 2026 Upward Spiral Productions
        </p>
      </div>
    </footer>
  </body>
</html>
